<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 任务标签 -->
    <key>Label</key>
    <string>com.xiaomi.workbench-update</string>

    <!-- 执行的命令 -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/stonekhun/Desktop/mi-work/work-workflow/scripts/daily-update.sh</string>
    </array>

    <!-- 每天早上 9:00 运行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 日志输出 -->
    <key>StandardOutPath</key>
    <string>/Users/stonekhun/Desktop/mi-work/work-workflow/update.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/stonekhun/Desktop/mi-work/work-workflow/update-error.log</string>

    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
